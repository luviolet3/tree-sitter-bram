{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "bram",
      "camelcase": "Bram",
      "title": "Bram",
      "scope": "source.bram",
      "file-types": [
        "bram"
      ],
      "injection-regex": "^bram$",
      "class-name": "TreeSitterBram"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Bram parser for tree-sitter",
    "authors": [
      {
        "name": "violet Lu",
        "url": "luv.iolet.org"
      }
    ],
    "links": {
      "repository": "https://github.com/luviolet3/tree-sitter-bram",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": true
  }
}